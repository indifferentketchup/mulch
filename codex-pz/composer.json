{
  "name": "indifferentketchup/codex-pz",
  "description": "Generic PHP log parsing and analysis framework.",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "indifferentketchup",
      "email": "samkintop@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^12"
  },
  "autoload": {
    "psr-4": {
      "IndifferentKetchup\\CodexPz\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IndifferentKetchup\\CodexPz\\Test\\Src\\": "test/src/",
      "IndifferentKetchup\\CodexPz\\Test\\Tests\\": "test/tests/"
    }
  },
  "scripts": {
    "test": "phpunit test/tests"
  },
  "extra": {
    "branch-alias": {
      "dev-pz-enrichment-bootstrap": "0.6.x-dev"
    }
  }
}
